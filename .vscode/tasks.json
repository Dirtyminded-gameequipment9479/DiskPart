{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "compile",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceRoot}",
                "env": {
                    "PATH": "${env:PATH}:${userHome}/.vscode/extensions/bartmanabyss.amiga-debug-1.7.9/bin/linux/opt/bin:${userHome}/.vscode/extensions/bartmanabyss.amiga-debug-1.7.9/bin/linux"
                }
            },
            "args": [
                "-j4"
            ],
            "problemMatcher": [
                {
                    "base": "$gcc",
                    "fileLocation": "absolute"
                }
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "make",
            "options": {
                "cwd": "${workspaceRoot}"
            },
            "args": [ "clean" ],
            "problemMatcher": []
        }
    ]
}
